generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String      @id
  name           String
  whatsappNumber String
  university     Int
  uploadedMedia  MediaFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Case {
  id           String @id @default(cuid())
  title        String
  complaint    String
  difficulty   Int
  category     Int
  speciality   Int
  name         String
  age          Int
  gender       Int
  weight       Float
  height       Float
  briefHistory String
  objective    String
  actor        String
  diagnosis    String
  differential String @default("")

  bodySystems    BodySystem[]
  investigations Investigation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model BodySystem {
  id    String          @id @unique @default(cuid())
  label BodySystemLabel
  icon  String

  caseId                String
  case                  Case                   @relation(fields: [caseId], references: [id])
  examinationTechniques ExaminationTechnique[]
}

model ExaminationTechnique {
  id    String                    @id @unique @default(cuid())
  label ExaminationTechniqueLabel
  icon  String

  bodySystemId     String
  bodySystem       BodySystem        @relation(fields: [bodySystemId], references: [id])
  examinationAreas ExaminationArea[]
}

model ExaminationArea {
  id String @id @unique @default(cuid())

  label String

  examinationTechniqueId String
  examinationTecnique    ExaminationTechnique @relation(fields: [examinationTechniqueId], references: [id])
  examinationFindings    ExaminationFinding[]
}

model ExaminationFinding {
  id String @id @unique @default(cuid())

  type        ExaminationFindingType
  normal      Boolean?               @default(true)
  description String

  examinationAreaId String
  examinationArea   ExaminationArea @relation(references: [id], fields: [examinationAreaId])
  mediaFileId       String?
  mediaFile         MediaFile?      @relation(fields: [mediaFileId], references: [id])
}

model Investigation {
  id       String  @id @unique @default(cuid())
  label    String
  guidance String?

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])

  investigationResultId String              @unique
  investigationResult   InvestigationResult @relation(fields: [investigationResultId], references: [id])
}

model InvestigationResult {
  id            String         @id @default(cuid())
  investigation Investigation?
  reference     String?
  value         String?
  description   String

  tableData   InvestigationTableData[]
  mediaFile   MediaFile?               @relation(fields: [mediaFileId], references: [id])
  mediaFileId String?
}

model InvestigationTableData {
  id        String @id @default(cuid())
  name      String
  value     Float
  unit      String
  reference String

  investigationResult   InvestigationResult @relation(fields: [investigationResultId], references: [id])
  investigationResultId String
}

model MediaFile {
  id           String  @id @default(cuid())
  diskName     String  @unique
  displayName  String
  mimeType     String
  size         Int
  metadata     Json?
  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  examinationFindings  ExaminationFinding[]
  investigationResults InvestigationResult[]

  createdAt  DateTime @default(now())
  uploadedAt DateTime @default(now())

  @@index([displayName])
}

model GradingAttempt {
  id           String         @id @default(cuid())
  studentId    String
  caseId       String
  section      GradingSection
  score        Float
  feedback     String
  rawResponse  Json?
  missingItems String[]
  isCorrect    Boolean?
  createdAt    DateTime       @default(now())

  @@unique([studentId, caseId, section]) // one attempt per section per student per case
  @@index([id, caseId])
}

enum GradingSection {
  HISTORY
  EXAM
  INVESTIGATIONS
  DIAGNOSIS
}

enum BodySystemLabel {
  General
  Cardiovascular
  Respiratory
  Abdomen
  Neurological
  Extremities
}

enum ExaminationTechniqueLabel {
  Inspect
  Palpate
  Auscultate
  Percuss
}

enum ExaminationFindingType {
  img
  audio
  video
  text
}
